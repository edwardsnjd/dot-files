#!/usr/bin/env bash

# NAME
#   git-browse-log2 - Interactive FZF browse of git lg
#
# USAGE
#   git browse-log2 [git lg options]

function GitBrowseLog2 {
  local pretty="format:%C(brightblack)⟨%C(reset)%C(yellow)%h%C(reset)%C(brightblack)⟩%C(reset) %C(dim blue)%ad%C(reset) %s %C(cyan)<%aN>%C(red)%d%C(reset)"
  local preview="[ -n '{2}' ] && git show --color --stat --patch {2} | less -c -+F -+X"

  git log \
    --graph \
    --color \
    --pretty="$pretty" \
    --date=short \
    --decorate \
    "$@" \
    | fzf \
      --ansi \
      --layout=reverse-list \
      --no-sort \
      --delimiter="⟨|⟩" \
      --accept-nth="2" \
      --bind="enter:execute($preview)"
}

GitBrowseLog2 "$@"
