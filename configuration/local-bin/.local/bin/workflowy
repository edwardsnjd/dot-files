#!/usr/bin/env bash

# NAME
#   workflowy - Generic CLI wrapper for Workflowy API
#
# SYNOPSIS
#   workflowy list <parent_id>
#   workflowy create <parent_id> <title> [note]
#   workflowy complete <node_id>
#
# DESCRIPTION
#   Generic command-line interface for Workflowy API operations.
#
# ENVIRONMENT VARIABLES
#   WORKFLOWY_BASE_URL      - Override default workflowy.com URL (optional)
#   WORKFLOWY_API_KEY       - API key (checked first) (required unless WORKFLOWY_API_KEY_FILE is provided)
#   WORKFLOWY_API_KEY_FILE  - Path to file containing the API key (required unless WORKFLOWY_API_KEY is provided)

set -o nounset
set -o errexit
set -o pipefail

WORKFLOWY_BASE_URL="${WORKFLOWY_BASE_URL:-https://workflowy.com}"
WORKFLOWY_API_KEY_FILE="${WORKFLOWY_API_KEY_FILE:-${XDG_DATA_HOME}/.workflowy-api-key}"

function Main() {
  local command="${1:-}"

  case "$command" in
    create) shift && CreateNode "$@" ;;
    list) shift && ListNodes "$@" ;;
    complete) shift && CompleteNode "$@" ;;
    help|--help|-h) ShowHelp ;;
    *)
      echo "ERROR: Unknown command: '$command'" >&2
      exit 1
      ;;
  esac
}

function CreateNode() {
  local parentId="${1:-}"
  local title="${2:-}"
  local note="${3:-}"

  if [[ -z "$parentId" || -z "$title" ]]; then
    echo "ERROR: create requires <parent_id> <title> [note]" >&2
    exit 1
  fi

  local payload="$(
    jq -n \
      --arg parentId "$parentId" \
      --arg title "$title" \
      --arg note "$note" \
      '{parent_id: $parentId, name: $title, note: $note, position: "bottom"}'
  )"

  ApiRequest \
    -X POST \
    -H "Content-Type: application/json" \
    -d "$payload" \
    "${WORKFLOWY_BASE_URL}/api/v1/nodes"
}

function ListNodes() {
  local parentId="${1:-}"

  if [[ -z "$parentId" ]]; then
    echo "ERROR: list requires <parent_id>" >&2
    exit 1
  fi

  ApiRequest "${WORKFLOWY_BASE_URL}/api/v1/nodes?parent_id=${parentId}"
}

function CompleteNode() {
  local nodeId="${1:-}"

  if [[ -z "$nodeId" ]]; then
    echo "ERROR: complete requires <node_id>" >&2
    exit 1
  fi

  ApiRequest \
    -X POST \
    "${WORKFLOWY_BASE_URL}/api/v1/nodes/${nodeId}/complete"
}

function ApiRequest() {
  local apiKey="$(GetApiKey)"

  curl -s -H "Authorization: Bearer ${apiKey}" "$@"
}

function GetApiKey() {
  # Check env var first
  if [[ -n "${WORKFLOWY_API_KEY:-}" ]]; then
    echo "$WORKFLOWY_API_KEY"
    return
  fi

  # Fall back to file
  if [[ -s "$WORKFLOWY_API_KEY_FILE" ]]; then
    cat "$WORKFLOWY_API_KEY_FILE"
    return
  fi

  echo "ERROR: No API key found. Set WORKFLOWY_API_KEY or provide key in $WORKFLOWY_API_KEY_FILE" >&2
  exit 1
}

Main "$@"
