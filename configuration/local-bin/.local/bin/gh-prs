#!/usr/bin/env bash

# NAME
#   gh-prs - list Github PRs
#
# USAGE
#   gh-prs REPO [--author AUTHOR] [--year YEAR]
#
# EXAMPLE
#   gh-prs owner/repo --author foobar
#
# OUTPUT
#   TSV with the columns:
#     repo
#     number
#     author
#     title
#     body
#     createdAt
#     mergedAt
#     closedAt
#     state
#     comments
#     reviews
#     commits
#     changedFiles
#     additions
#     deletions

set -o nounset
set -o errexit
set -o pipefail
#set -o xtrace

function Main() {
  local repo="${1:?Requires repo e.g. owner/repo}"
  local year=""
  local author=""

  local otherArgs=()
  while [[ $# -gt 0 ]]; do
    case $1 in
      --author) author="$2" && shift && shift ;;
      --year) year="$2" && shift && shift ;;
      -*|--*) echo "Unknown option $1" >&2 && exit 1 ;;
      *) otherArgs+=("$1") && shift ;;
    esac
  done
  set -- "${otherArgs[@]}" # restore positional parameters

  local repoQuery="repo:${repo}"
  local authorQuery="$([ -n "$author" ] && printf "author:$author")"
  local dateQuery="$([ -n "$year" ] && printf "year:$year")"

  echo "repo	number	author	title	body	createdAt	mergedAt	closedAt	state	comments	reviews	commits	changedFiles	additions	deletions"

  gh api graphql \
    --paginate \
    --raw-field query="$(QueryGQL)" \
    --field searchQuery="is:pr ${repoQuery} ${authorQuery} ${dateQuery}" \
    --jq '
      .data.search.nodes[] | [
        .repository.nameWithOwner,
        .number,
        .author.login,
        .title,
        (.body | length),
        .createdAt, .mergedAt, .closedAt,
        .state,
        .comments.totalCount,
        .reviews.totalCount,
        .commits.totalCount,
        .changedFiles, .additions, .deletions
      ] | @tsv
    '
}

function QueryGQL() {
  cat <<- "GQL"
	query($searchQuery: String!, $endCursor: String) {
	  search(
	    type: ISSUE
	    query: $searchQuery
	    after: $endCursor
	    first: 25
	  ) {
	    pageInfo {
	      hasNextPage
	      endCursor
	    }
	    nodes {
	      ... on PullRequest {
	        repository { nameWithOwner }
	        number
	        author { login }
	        title
	        body
	        createdAt
	        mergedAt
	        closedAt
	        state
	        comments { totalCount }
	        reviews { totalCount }
	        commits { totalCount }
	        changedFiles
	        additions
	        deletions
	      }
	    }
	  }
	}
	GQL
}

Main "$@"
