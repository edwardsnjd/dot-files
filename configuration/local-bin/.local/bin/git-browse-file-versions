#!/usr/bin/env bash

# NAME
#   git-browse-file-versions - fzf browse git history of a file (versions)
#
# USAGE
#   git browse-file-versions <path>

function GitBrowseFileVersions() {
  local path="${1:?Must supply the path to browse}"

  ListCommitsAndPaths "$path" | SelectGitCommit | while read sha p; do
    echo "# git show $sha:$p"
    git show "$sha:$p" | bat --style=header --file-name="$sha:$p"
  done
}

function SelectGitCommit() {
  local path="$1"

  local preview="git show {2}:{1} | bat --style=header --color=always --file-name={2}:{1}"

  fzf \
    --ansi \
    --layout=reverse \
    --no-sort \
    --multi \
    --with-nth="2.." \
    --accept-nth="2,1" \
    --preview="$preview" \
    --bind "ctrl-/:change-preview-window(bottom|hidden|default)"
}

# Output is one line per commit:
#  <PATH> <HASH> ...
function ListCommitsAndPaths() {
  local path="$1"

  local pretty="tformat:COMMIT %C(yellow)%h%C(reset) %C(dim blue)%ad%C(reset) %s %C(cyan)<%an>%C(red)%d%C(reset)"

  git log \
    --pretty="$pretty" \
    --date=short \
    --name-status \
    --color \
    --follow \
    -- "$path" \
  | sed -E '/^$/d' \
  | awk -v current="$path" '
    # Rename status lines look like: R<score> old_path new_path
    $1 ~ /^R/ { current = $2 }
    $1 == "COMMIT" { $1 = current; print }
  '
}

GitBrowseFileVersions "$@"
