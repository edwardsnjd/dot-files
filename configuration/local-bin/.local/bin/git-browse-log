#!/usr/bin/env bash

# NAME
#   git-browse-log - fzf browse git log with preview
#
# USAGE
#   git-browse-log [git log args]

function GitBrowseLog {
  local pretty="format:%C(brightblack)⟨%C(reset)%C(yellow)%h%C(reset)%C(brightblack)⟩%C(reset) %C(dim blue)%ad%C(reset) %s %C(cyan)<%aN>%C(red)%d%C(reset)"
  local preview="[ -n '{2}' ] && git show --color --stat --patch {2} | less -c -+F -+X"

  git log \
    --graph \
    --color \
    --pretty="$pretty" \
    --date=short \
    --decorate \
    "$@" \
    | fzf \
      --ansi \
      --layout=reverse-list \
      --no-sort \
      --delimiter="⟨|⟩" \
      --preview="$preview" \
      --accept-nth="2" \
      --bind "ctrl-/:change-preview-window(bottom|hidden|default)"
}

GitBrowseLog "$@"
