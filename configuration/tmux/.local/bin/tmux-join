#!/usr/bin/env bash

# NAME
#   tmux-join - Attach or switch to selected session.
#
# SYNOPSIS
#   tmux-join <session>

set -o nounset
set -o errexit

function JoinSession() {
  local session="${1:-}"

  if [[ -n "${session}" ]]
  then
    if [[ -z "${TMUX:-}" ]]; then
      exec tmux attach-session -t "${session}"
    else
      exec tmux switch-client -t "${session}"
    fi
  fi
}

JoinSession "$@"
