FROM qwen3.5:9b

# https://huggingface.co/Qwen/Qwen3.5-9B
PARAMETER temperature 0.6
PARAMETER top_p 0.95
PARAMETER top_k 20
PARAMETER min_p 0.0
PARAMETER presence_penalty 0.0
#PARAMETER repetition_penalty 1.0

# This is lower than the 128k they recommend but
# any larger and we hit OOM
PARAMETER num_ctx 50000
