FROM qwen3-coder:30b

# https://huggingface.co/Qwen/Qwen3-Coder-30B-A3B-Instruct
PARAMETER temperature 0.1
PARAMETER top_p 0.95
PARAMETER top_k 20
PARAMETER min_p 0.0
PARAMETER presence_penalty 0.0
PARAMETER repeat_penalty 1.0

# Overly large but allows sharing model instance with reasoning one
PARAMETER num_ctx 30000
# Limit prediction
PARAMETER num_predict 20

SYSTEM """
You are a code completion assistant.  Respond ONLY with the characters to insert.
"""
