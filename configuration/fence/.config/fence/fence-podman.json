{
  "$schema": "https://raw.githubusercontent.com/Use-Tusk/fence/main/docs/schema/fence.schema.json",
  "extends": "./fence.json",
  "network": {
    "allowedDomains": [
      // Podman socket
      "127.0.0.1",
    ]
  },
  "filesystem": {
    "allowRead": [
      // Podman identity
      "~/.local/share/containers/podman/machine/machine",
      "~/.ssh/known_hosts",
    ],
  }
}
